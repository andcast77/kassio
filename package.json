{
  "name": "kassio",
  "version": "0.1.4",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "dev": "pnpm --filter @kassio/runtime build && node scripts/dev.mjs",
    "start:embedded": "node scripts/kassio-start.mjs",
    "dev:api": "pnpm --filter @kassio/api dev",
    "dev:desktop": "pnpm --filter @kassio/desktop dev",
    "tauri:dev": "pnpm --filter @kassio/desktop tauri:dev",
    "tauri:build": "pnpm --filter @kassio/desktop tauri:build",
    "db:migrate": "pnpm --filter @kassio/database migrate:dev",
    "db:seed": "pnpm --filter @kassio/database db:seed",
    "db:studio": "pnpm --filter @kassio/database studio",
    "build": "pnpm -r run build",
    "test": "pnpm --filter @kassio/api test && pnpm --filter @kassio/desktop test && pnpm --filter @kassio/runtime test",
    "test:api": "pnpm --filter @kassio/api test",
    "typecheck": "pnpm -r run typecheck"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  }
}
