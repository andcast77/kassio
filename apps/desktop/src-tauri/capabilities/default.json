{
  "$schema": "https://schema.tauri.app/schema/2/capability.json",
  "identifier": "default",
  "description": "Default capabilities for Kassio",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-spawn",
    "shell:allow-kill",
    "updater:default",
    "process:allow-restart",
    "core:app:allow-app-exit"
  ]
}
