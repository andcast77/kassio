{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kassio",
  "version": "0.1.2",
  "identifier": "app.kassio.desktop",
  "build": {
    "beforeDevCommand": "pnpm --dir ../.. dev:embedded:ui",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "pnpm build && node ../../scripts/stage-backend.mjs",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Kassio",
        "width": 1360,
        "height": 768,
        "minWidth": 1280,
        "minHeight": 720,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage", "msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerHooks": "./windows/hooks.nsh"
      }
    },
    "linux": {
      "deb": {
        "postInstallScript": "./install/postinst.sh"
      }
    },
    "resources": {
      "resources/": "",
      "install/install-setup.cmd": "install-setup.cmd"
    }
  }
}
