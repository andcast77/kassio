{
  "name": "kassio",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm run db:up && concurrently -n api,ui -c blue,green \"pnpm --filter @kassio/api dev\" \"pnpm --filter @kassio/desktop dev\"",
    "dev:api": "pnpm --filter @kassio/api dev",
    "dev:desktop": "pnpm --filter @kassio/desktop dev",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:migrate": "pnpm --filter @kassio/database migrate:dev",
    "db:seed": "pnpm --filter @kassio/database db:seed",
    "db:setup": "pnpm db:up && pnpm db:migrate && pnpm db:seed",
    "db:studio": "pnpm --filter @kassio/database studio",
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  }
}
