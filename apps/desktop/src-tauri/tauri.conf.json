{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kassio",
  "version": "0.1.4",
  "identifier": "app.kassio.desktop",
  "build": {
    "beforeDevCommand": "pnpm --dir ../.. dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build && node ../../scripts/stage-backend.mjs",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Kassio",
        "width": 1360,
        "height": 768,
        "minWidth": 1280,
        "minHeight": 720,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": "v1Compatible",
    "targets": ["deb", "appimage", "msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "installerHooks": "./windows/hooks.nsh"
      }
    },
    "linux": {
      "deb": {
        "postInstallScript": "./install/postinst.sh"
      }
    },
    "resources": {
      "resources/": "",
      "install/install-setup.cmd": "install-setup.cmd"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU1OTBDNzBCRTM4RTVDRDEKUldUUlhJN2pDOGVRVlFqVDlGWFZXbThoV3E1SExQOHFsdDNmek5mQTNBZGNwTUpZK3o4bS9OTzYK",
      "endpoints": [
        "https://github.com/andcast77/kassio/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "quiet"
      }
    }
  }
}
